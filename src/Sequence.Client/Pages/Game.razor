@page "/game/{RoomCode}"
@using Sequence.Core.Cards
@using Sequence.Core.Contracts
@using Sequence.Core.Game
@using Sequence.Client.Services
@inject GameClient Client
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Sequence — @RoomCode</PageTitle>

@if (State is null)
{
    <p class="status-line">Connecting…</p>
}
else
{
    <div class="game-shell">
        <header class="game-header">
            <div>
                <strong>Room:</strong> @State.RoomCode
            </div>
            <ul class="player-list">
                @foreach (var p in State.Players)
                {
                    <li class="@ColorClass(p.Color) @(p.Id == State.CurrentPlayerId ? "current-turn" : "")">
                        @p.Name — @p.SequenceCount / @State.SequencesToWin sequences
                        @if (p.Id == MyPlayerId) { <span> (you)</span> }
                    </li>
                }
            </ul>
            <div>Cards left in deck: @State.DeckCount</div>
        </header>

        @if (!string.IsNullOrEmpty(Client.LastError))
        {
            <p class="error">@Client.LastError</p>
        }

        @if (State.Status == GameStatus.WaitingForPlayers)
        {
            <div class="waiting-panel">
                <p>Waiting for players. Share the room code <strong>@State.RoomCode</strong> with others.</p>
                @if (State.Players.Count >= 2)
                {
                    <button class="btn-primary" @onclick="StartGame">Start Game</button>
                }
                else
                {
                    <p>Need at least 2 players to start.</p>
                }
            </div>
        }
        else if (State.Status == GameStatus.Completed)
        {
            <div class="winner-banner">
                🏆 @WinnerName() wins!
            </div>
        }
        else
        {
            <p class="status-line">
                @if (State.CurrentPlayerId == MyPlayerId)
                {
                    <span>Your turn — @(selectedCard is null ? "select a card to play" : $"select a board space for {DescribeCard(selectedCard.Value)}")</span>
                }
                else
                {
                    <span>Waiting for @CurrentPlayerName()…</span>
                }
            </p>
        }

        <div class="board" style="grid-template-columns: repeat(10, 1fr);">
            @foreach (var cell in State.Board.OrderBy(c => c.Row).ThenBy(c => c.Col))
            {
                <div class="cell @(cell.IsFree ? "free" : "") @(cell.PartOfCompletedSequence ? "in-sequence" : "") @(CanTargetCell(cell) ? "targetable" : "")"
                     @onclick="() => OnCellClicked(cell)">
                    @if (cell.IsFree)
                    {
                        <span class="free-label">★</span>
                    }
                    else if (cell.Card is not null)
                    {
                        <span class="@SuitClass(cell.Card.Value.Suit)">@DescribeCard(cell.Card.Value)</span>
                    }
                    @if (cell.ChipOwnerId is not null)
                    {
                        <div class="chip @ColorClass(ColorOf(cell.ChipOwnerId.Value))"></div>
                    }
                </div>
            }
        </div>

        @if (State.Status == GameStatus.InProgress)
        {
            <div class="hand">
                @foreach (var card in State.YourHand)
                {
                    <button class="card @SuitClass(card.Suit) @(IsSelected(card) ? "selected" : "")"
                            disabled="@(State.CurrentPlayerId != MyPlayerId)"
                            @onclick="() => SelectCard(card)">
                        @DescribeCard(card)
                    </button>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public string RoomCode { get; set; } = "";

    private Card? selectedCard;

    private GameStateSnapshot? State => Client.State;
    private Guid? MyPlayerId => Client.PlayerId;

    protected override void OnInitialized()
    {
        Client.OnChange += HandleChange;

        // Client.PlayerId is set synchronously as soon as CreateRoomAsync/JoinRoomAsync succeeds,
        // before the first StateUpdated snapshot has necessarily rendered. Only treat this as "no
        // active session" (e.g. a hard page refresh, since WASM state is in-memory only) when we
        // never joined a room at all — don't bounce back to "/" just because State hasn't arrived yet.
        if (Client.PlayerId is null)
        {
            Nav.NavigateTo("/");
        }
    }

    private void HandleChange() => InvokeAsync(StateHasChanged);

    private async Task StartGame() => await Client.StartGameAsync(RoomCode);

    private void SelectCard(Card card)
    {
        selectedCard = IsSelected(card) ? null : card;
    }

    private bool IsSelected(Card card) => selectedCard is not null && selectedCard.Value == card;

    private async Task OnCellClicked(CellSnapshot cell)
    {
        if (selectedCard is null || cell.IsFree || State is null) return;
        if (State.CurrentPlayerId != MyPlayerId) return;

        var moveType = selectedCard.Value.IsOneEyedJack ? MoveType.RemoveChip : MoveType.PlaceChip;
        var move = new MoveRequest(selectedCard.Value, cell.Row, cell.Col, moveType);
        selectedCard = null;
        await Client.PlayMoveAsync(RoomCode, move);
    }

    private bool CanTargetCell(CellSnapshot cell)
    {
        if (selectedCard is null || cell.IsFree || State is null) return false;
        if (State.CurrentPlayerId != MyPlayerId) return false;

        if (selectedCard.Value.IsOneEyedJack)
            return cell.ChipOwnerId is not null && cell.ChipOwnerId != MyPlayerId && !cell.PartOfCompletedSequence;

        if (selectedCard.Value.IsTwoEyedJack)
            return cell.ChipOwnerId is null;

        return cell.ChipOwnerId is null && cell.Card == selectedCard.Value;
    }

    private PlayerColor ColorOf(Guid playerId) =>
        State!.Players.First(p => p.Id == playerId).Color;

    private string CurrentPlayerName() =>
        State?.Players.FirstOrDefault(p => p.Id == State.CurrentPlayerId)?.Name ?? "";

    private string WinnerName() =>
        State?.Players.FirstOrDefault(p => p.Id == State.WinnerId)?.Name ?? "";

    private static string ColorClass(PlayerColor color) => color switch
    {
        PlayerColor.Blue => "color-blue",
        PlayerColor.Green => "color-green",
        PlayerColor.Red => "color-red",
        _ => ""
    };

    private static string SuitClass(Suit suit) =>
        suit is Suit.Hearts or Suit.Diamonds ? "suit-red" : "suit-black";

    private static string DescribeCard(Card card)
    {
        var rank = card.Rank switch
        {
            Rank.Two => "2",
            Rank.Three => "3",
            Rank.Four => "4",
            Rank.Five => "5",
            Rank.Six => "6",
            Rank.Seven => "7",
            Rank.Eight => "8",
            Rank.Nine => "9",
            Rank.Ten => "10",
            Rank.Jack => "J",
            Rank.Queen => "Q",
            Rank.King => "K",
            Rank.Ace => "A",
            _ => "?"
        };
        var suit = card.Suit switch
        {
            Suit.Clubs => "♣",
            Suit.Diamonds => "♦",
            Suit.Hearts => "♥",
            Suit.Spades => "♠",
            _ => "?"
        };
        return $"{rank}{suit}";
    }

    public void Dispose() => Client.OnChange -= HandleChange;
}
